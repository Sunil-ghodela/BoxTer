{
  "name": "boxter",
  "version": "1.0.1",
  "description": "A tiling workspace manager — run terminals, browsers, and notes side by side in resizable panels.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --no-sandbox\"",
    "dev:sandbox": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "build:win": "npm run build:renderer && electron-builder --win",
    "pack": "npm run build:renderer && electron-builder --dir"
  },
  "keywords": [
    "workspace",
    "terminal",
    "tiling",
    "dashboard",
    "productivity",
    "electron"
  ],
  "author": {
    "name": "Sunil-ghodela",
    "url": "https://github.com/Sunil-ghodela"
  },
  "license": "MIT",
  "homepage": "https://github.com/Sunil-ghodela/BoxTer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sunil-ghodela/BoxTer.git"
  },
  "bugs": {
    "url": "https://github.com/Sunil-ghodela/BoxTer/issues"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.3.2",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@lydell/node-pty": "1.2.0-beta.12",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-grid-layout": "^1.5.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "build": {
    "appId": "com.boxter.app",
    "productName": "BoxTer",
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "dist/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": {
      "provider": "github",
      "owner": "Sunil-ghodela",
      "repo": "BoxTer"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Sunil-ghodela <sunil-ghodela@users.noreply.github.com>"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
